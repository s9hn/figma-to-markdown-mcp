{
  "name": "figma-compaction-mcp",
  "version": "3.0.0",
  "description": "MCP bridge that prunes Figma design context into compact plain-text context for agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "figma-compaction-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\" && tsc && node --input-type=module -e \"import { cpSync } from 'node:fs'; for (const file of ['design-context-analyzer.js', 'compact-context.js']) cpSync('src/' + file, 'dist/' + file);\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test test/*.test.js test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "figma",
    "compaction",
    "compact-context",
    "design-to-code",
    "token-reduction"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tiktoken": "^1.0.22",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "author": "s9hn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s9hn/figma-compaction-mcp.git"
  },
  "homepage": "https://github.com/s9hn/figma-compaction-mcp#readme",
  "bugs": {
    "url": "https://github.com/s9hn/figma-compaction-mcp/issues"
  }
}
